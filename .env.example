PORT=3000

DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_DB_ENGINE=django.contrib.gis.db.backends.postgis

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=minegis
PGSCHEMA=public

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=minegis
POSTGRES_SCHEMA=public

CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174

# Frontend Cesium terrain configuration (optional)
# If configured, the app uses this terrain service URL first.
VITE_CESIUM_TERRAIN_URL=
# If using Cesium World Terrain, configure your Cesium ion token.
VITE_CESIUM_ION_ACCESS_TOKEN=

# Optional: set explicitly when GeoDjango cannot auto-detect native libs
# GDAL_LIBRARY_PATH=C:\Program Files\PostgreSQL\18\bin\libgdal-35.dll
# GEOS_LIBRARY_PATH=C:\Program Files\PostgreSQL\18\bin\libgeos_c.dll
